---
export interface Props {
  href?: string;
  class?: string;
  hover?: boolean;
}
const { href, class: className = '', hover = false } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'glass block rounded-2xl p-6',
    hover && 'glass-hover',
    className,
  ]}
  {...href ? { 'data-astro-prefetch': true } : {}}
>
  <slot />
</Tag>
