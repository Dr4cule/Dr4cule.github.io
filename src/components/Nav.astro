---
import { site, nav } from '@/config';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---
<style>
  /* Subtle shrink/blur intensify on the nav once the page is scrolled. */
  header[data-scrolled='true'] nav {
    --glass-bg-opacity: 0.7;
  }
  :root.dark header[data-scrolled='true'] nav {
    --glass-bg-opacity: 0.08;
  }
</style>

<header id="site-header" class="sticky top-0 z-50 px-4 pt-4 sm:px-6 lg:px-8">
  <nav
    class="glass mx-auto flex max-w-6xl items-center justify-between rounded-2xl px-4 py-2.5 transition-all duration-300"
    aria-label="Main"
  >
    <a href="/" class="group flex items-center gap-2.5 font-display text-lg font-bold">
      <img
        src={site.avatar}
        alt={site.name}
        width="32"
        height="32"
        class="avatar-ring h-8 w-8 rounded-full object-cover transition-transform duration-300 group-hover:scale-110"
      />
      <span class="gradient-text">{site.name}</span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-1 md:flex">
      {nav.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'rounded-lg px-3 py-1.5 text-sm font-medium transition-colors',
              isActive(item.href) ? 'text-accent' : 'text-muted hover:text-ink',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-2">
      <!-- Command palette trigger (desktop hint) -->
      <button
        id="cmdk-open"
        class="hidden items-center gap-2 rounded-lg px-2.5 py-1.5 text-xs text-muted transition-colors hover:text-ink lg:flex"
        aria-label="Open command palette"
      >
        <kbd class="glass rounded px-1.5 py-0.5 font-mono text-[10px]">⌘K</kbd>
      </button>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        class="grid h-9 w-9 place-items-center rounded-lg text-ink transition-colors hover:text-accent"
        aria-label="Toggle dark mode"
      >
        <svg class="hidden h-5 w-5 dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
        </svg>
        <svg class="block h-5 w-5 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
        </svg>
      </button>

      <!-- Mobile menu toggle -->
      <button
        id="menu-toggle"
        class="grid h-9 w-9 place-items-center rounded-lg text-ink md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="glass mx-auto mt-2 hidden max-w-6xl rounded-2xl p-2 md:!hidden"
  >
    <ul class="flex flex-col">
      {nav.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block rounded-lg px-4 py-2.5 text-sm font-medium transition-colors',
              isActive(item.href) ? 'text-accent' : 'text-muted hover:text-ink',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  function initNav() {
    // NOTE: we use `.onclick =` (not addEventListener) so binding is
    // idempotent — Astro's View Transitions fire `astro:page-load` on the
    // initial load too, so init can run more than once; property assignment
    // guarantees exactly one handler instead of stacking them.

    // Theme toggle — delegates to the centralised setter in BaseLayout so the
    // <html> class, localStorage, and mobile theme-color all stay in sync.
    const toggle = document.getElementById('theme-toggle');
    if (toggle) {
      toggle.onclick = () => (window as any).__toggleTheme?.();
    }

    // Mobile menu
    const menuBtn = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (menuBtn) {
      menuBtn.onclick = () => {
        const open = menu?.classList.toggle('hidden') === false;
        menuBtn.setAttribute('aria-expanded', String(open));
      };
    }

    // Command palette trigger
    const cmdkOpen = document.getElementById('cmdk-open');
    if (cmdkOpen) {
      cmdkOpen.onclick = () => (window as any).openCommandPalette?.();
    }

    // Frost the nav a touch more once scrolled. Query the header fresh each
    // time so it keeps working across view-transition DOM swaps.
    const setScrolled = () =>
      document
        .getElementById('site-header')
        ?.setAttribute('data-scrolled', String(window.scrollY > 12));
    if (!(window as any)._navScroll) {
      (window as any)._navScroll = true;
      window.addEventListener('scroll', setScrolled, { passive: true });
    }
    setScrolled();
  }

  // Bind on first load and after every View Transitions navigation.
  document.addEventListener('astro:page-load', initNav);
</script>
