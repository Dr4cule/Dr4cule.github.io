---
import { socials } from '@/config';

export interface Props {
  class?: string;
  /** tailwind size classes for each icon button, e.g. 'h-10 w-10' */
  buttonClass?: string;
}
const { class: className = '', buttonClass = 'h-10 w-10' } = Astro.props;

// Brand SVG paths (24×24, fill=currentColor).
const ICONS: Record<string, string> = {
