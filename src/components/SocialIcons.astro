    'M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z',
};

const order = ['github', 'twitter', 'linkedin', 'discord', 'youtube', 'email'] as const;
const items = order
  .map((key) => {
    const raw = (socials as Record<string, string>)[key];
    if (!raw) return null;
    const href = key === 'email' ? `mailto:${raw}` : raw;
    return { key, href, label: key[0].toUpperCase() + key.slice(1), path: ICONS[key] };
  })
  .filter((x): x is NonNullable<typeof x> => x !== null);
---

{items.length > 0 && (
  <div class:list={['flex items-center gap-2.5', className]}>
    {items.map((i) => (
      <a
        href={i.href}
        target={i.key === 'email' ? undefined : '_blank'}
        rel="noopener"
        aria-label={i.label}
        title={i.label}
        class:list={[
          'group grid place-items-center rounded-full glass glass-hover text-muted transition-colors hover:text-accent',
          buttonClass,
        ]}
      >
        <svg viewBox="0 0 24 24" class="h-[45%] w-[45%] fill-current" aria-hidden="true">
          <path d={i.path} />
        </svg>
      </a>
    ))}
  </div>
)}
