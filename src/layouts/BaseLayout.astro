---
import { site, theme } from '@/config';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import CommandPalette from '@/components/CommandPalette.astro';
import '@/styles/global.css';
import { ViewTransitions } from 'astro:transitions';

export interface Props {
  title?: string;
  description?: string;
  /** Disable the big aurora background (e.g. for game pages). */
  bare?: boolean;
}

const {
  title,
  description = site.description,
  bare = false,
} = Astro.props;

const fullTitle = title ? `${title} · ${site.name}` : `${site.name} · ${site.tagline}`;
const canonical = new URL(Astro.url.pathname, site.url).toString();
const ogImage = new URL('/og.svg', site.url).toString();

// Inject the per-theme accent colors from config so light=gold / dark=red.
const themeCss = `:root{--accent:${theme.light.accent};--accent-soft:${theme.light.accentSoft};}:root.dark{--accent:${theme.dark.accent};--accent-soft:${theme.dark.accentSoft};}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <style is:inline set:html={themeCss}></style>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/avatar.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#faf9f6" data-dynamic />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={site.name} href="/rss.xml" />

    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- No-flash theme: runs before paint, before the body exists.
         Also re-applied on every View Transitions swap, because Astro replaces
         the <html> element (and its class) with the incoming page's markup. -->
    <script is:inline>
      (function () {
        // Default to the white & gold (light) theme; only go dark if the
        // visitor explicitly chose it before.
        function isDark() {
          try { return localStorage.getItem('theme') === 'dark'; } catch (e) { return false; }
        }
        function setMeta(dark) {
          var m = document.querySelector('meta[name="theme-color"][data-dynamic]');
          if (m) m.setAttribute('content', dark ? '#0b0809' : '#faf9f6');
        }
        function applyTheme() {
          var dark = isDark();
          document.documentElement.classList.toggle('dark', dark);
          setMeta(dark);
        }
        // Centralised theme setters used by the nav toggle + command palette,
        // so every entry point stays consistent.
        window.__setTheme = function (dark) {
          try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) {}
          applyTheme();
        };
        window.__toggleTheme = function () { window.__setTheme(!isDark()); };

        applyTheme();
        // `astro:after-swap` fires after the new DOM is in place but before
        // paint, so re-applying here avoids any flash of the wrong theme.
        // Bind once — this inline script re-runs on every View Transition.
        if (!window.__themeBound) {
          window.__themeBound = true;
          document.addEventListener('astro:after-swap', applyTheme);
        }
      })();
    </script>

    <ViewTransitions />
  </head>
  <body>
    <div id="scroll-progress" aria-hidden="true"></div>
    <div id="grain" aria-hidden="true"></div>

    <!-- Animated aurora background -->
    {!bare && (
      <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
        <div
          class="absolute -top-1/4 -left-1/4 h-[60vh] w-[60vh] rounded-full blur-3xl opacity-50 animate-aurora"
          style="background: radial-gradient(circle, rgb(var(--accent) / 0.5), transparent 70%);"
        >
        </div>
        <div
          class="absolute top-1/3 -right-1/4 h-[55vh] w-[55vh] rounded-full blur-3xl opacity-40 animate-aurora"
          style="background: radial-gradient(circle, rgb(var(--accent-soft) / 0.45), transparent 70%); animation-delay: -6s;"
        >
        </div>
        <div
          class="absolute -bottom-1/4 left-1/3 h-[50vh] w-[50vh] rounded-full blur-3xl opacity-30 animate-aurora"
          style="background: radial-gradient(circle, rgb(var(--accent) / 0.35), transparent 70%); animation-delay: -12s;"
        >
        </div>
      </div>
    )}

    <div id="cursor-glow" aria-hidden="true"></div>

    <Nav />

    <main class="relative z-10 mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
      <slot />
    </main>

    <Footer />
    <CommandPalette />

    <!-- Back to top -->
    <button
      id="to-top"
      aria-label="Back to top"
      class="glass glass-hover fixed bottom-6 right-6 z-[55] grid h-11 w-11 translate-y-20 place-items-center rounded-full text-ink opacity-0 transition-all duration-300"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" />
      </svg>
    </button>

    <!-- Tiny toast for easter eggs -->
    <div
      id="toast"
      class="glass fixed bottom-6 left-1/2 z-[60] -translate-x-1/2 translate-y-24 rounded-xl px-5 py-3 text-sm opacity-0 transition-all duration-500"
    >
    </div>

    <!-- Global behavior: cursor glow, scroll reveal, konami code -->
    <script>
      let cursorBound = false;
      let scrollBound = false;
      // One reveal observer for the whole session — re-created observers would
      // leak one per View Transitions navigation.
      let revealObserver: IntersectionObserver | null = null;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function initGlobal() {
        // ── Cursor glow follows the pointer (bind once) ──
        const glow = document.getElementById('cursor-glow');
        if (glow && !cursorBound) {
          cursorBound = true;
          let raf = 0;
          window.addEventListener('pointermove', (e) => {
            if (raf) return;
            raf = requestAnimationFrame(() => {
              glow.style.transform = `translate(${e.clientX}px, ${e.clientY}px) translate(-50%, -50%)`;
              raf = 0;
            });
          });
        }

        // ── Scroll progress bar + back-to-top visibility (window listener
        //    bound once; it re-queries the elements fresh every scroll so it
        //    survives View Transitions DOM swaps). ──
        if (!scrollBound) {
          scrollBound = true;
          const update = () => {
            const h = document.documentElement;
            const max = h.scrollHeight - h.clientHeight;
            const bar = document.getElementById('scroll-progress');
            if (bar) bar.style.width = max > 0 ? `${(h.scrollTop / max) * 100}%` : '0%';
            const t = document.getElementById('to-top');
            if (t) {
              const show = h.scrollTop > 400;
              t.style.opacity = show ? '1' : '0';
              t.style.transform = show ? 'translateY(0)' : 'translateY(5rem)';
              t.style.pointerEvents = show ? 'auto' : 'none';
            }
          };
          window.addEventListener('scroll', update, { passive: true });
          window.addEventListener('resize', update);
          update();
        }

        // The back-to-top BUTTON is replaced on every navigation, so bind its
        // click each page-load with idempotent `.onclick` on the fresh node.
        const toTop = document.getElementById('to-top') as HTMLButtonElement | null;
        if (toTop) {
          toTop.onclick = () =>
            window.scrollTo({ top: 0, behavior: reduceMotion ? 'auto' : 'smooth' });
        }

        // ── Scroll reveal (single shared observer; observe fresh nodes) ──
        if (!revealObserver) {
          revealObserver = new IntersectionObserver(
            (entries) => {
              for (const en of entries) {
                if (en.isIntersecting) {
                  en.target.classList.add('is-visible');
                  revealObserver!.unobserve(en.target);
                }
              }
            },
            { threshold: 0.12 }
          );
        }
        document
          .querySelectorAll('.reveal:not(.is-visible)')
          .forEach((el) => revealObserver!.observe(el));

        // ── Subtle 3D tilt on cards (skipped if reduced motion / touch) ──
        if (!reduceMotion && window.matchMedia('(hover: hover)').matches) {
          document.querySelectorAll('[data-tilt]').forEach((card) => {
            const el = card as HTMLElement;
            if (el.dataset.tiltBound) return;
            el.dataset.tiltBound = '1';
            const MAX = 6;
            el.addEventListener('pointermove', (e) => {
              const r = el.getBoundingClientRect();
              const px = (e.clientX - r.left) / r.width - 0.5;
              const py = (e.clientY - r.top) / r.height - 0.5;
              // Track the cursor 1:1 — disable the .glass-hover transition so
              // each pointermove isn't animated through a 300ms ease (jitter).
              el.style.transition = 'none';
              el.style.transform = `perspective(800px) rotateX(${(-py * MAX).toFixed(2)}deg) rotateY(${(px * MAX).toFixed(2)}deg) translateY(-4px)`;
            });
            el.addEventListener('pointerleave', () => {
              // Restore the CSS transition so the card eases smoothly back.
              el.style.transition = '';
              el.style.transform = '';
            });
          });
        }
      }

      // ── Toast helper (also used by other components) ──
      function showToast(msg: string) {
        const t = document.getElementById('toast');
        if (!t) return;
        t.textContent = msg;
        t.style.opacity = '1';
        t.style.transform = 'translate(-50%, 0)';
        window.clearTimeout((t as any)._timer);
        (t as any)._timer = window.setTimeout(() => {
          t.style.opacity = '0';
          t.style.transform = 'translate(-50%, 6rem)';
        }, 3000);
      }
      (window as any).showToast = showToast;

      // ── Konami code easter egg ──
      const KONAMI = [
        'ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown',
        'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight',
        'b', 'a',
      ];
      let kidx = 0;
      window.addEventListener('keydown', (e) => {
        const key = e.key.length === 1 ? e.key.toLowerCase() : e.key;
        if (key === KONAMI[kidx]) {
          kidx++;
          if (kidx === KONAMI.length) {
            kidx = 0;
            const on = document.body.classList.toggle('konami');
            // One Piece treasure mode — flip the accent to molten gold.
            if (on) {
              document.documentElement.style.setProperty('--accent', '255 196 0');
              document.documentElement.style.setProperty('--accent-soft', '255 224 130');
              showToast('🏴‍☠️ One Piece is real — treasure mode unlocked!');
            } else {
              document.documentElement.style.removeProperty('--accent');
              document.documentElement.style.removeProperty('--accent-soft');
              showToast('Treasure mode off.');
            }
          }
        } else {
          kidx = key === KONAMI[0] ? 1 : 0;
        }
      });

      // Runs on first load and after every View Transitions navigation.
      // (The konami listener above is bound once at module load.)
      document.addEventListener('astro:page-load', initGlobal);
    </script>
  </body>
</html>
