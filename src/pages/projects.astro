---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { projects } from '@/config';

// Unique tag list for the filter bar.
const allTags = ['All', ...Array.from(new Set(projects.flatMap((p) => p.tags)))];
---

<BaseLayout title="Projects" description="Things I've built.">
  <section class="py-12">
    <header class="mb-8 reveal">
      <span class="eyebrow">Projects</span>
      <h1 class="mt-4 font-display text-4xl font-bold sm:text-5xl">Things I've built</h1>
      <p class="mt-3 max-w-xl text-muted">
        A collection of things I've designed, built, and broken. Filter by tech below.
      </p>
    </header>

    <!-- Tag filter -->
    <div class="mb-8 flex flex-wrap gap-2 reveal" id="filter-bar">
      {allTags.map((t, i) => (
        <button
          data-filter={t}
          class:list={[
            'rounded-full px-4 py-1.5 text-sm font-medium transition-all',
            i === 0 ? 'bg-accent text-white' : 'glass text-muted hover:text-ink',
          ]}
        >
          {t}
        </button>
      ))}
    </div>

    <div id="project-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((p) => (
        <div data-tags={p.tags.join(',')}>
          <ProjectCard project={p} />
        </div>
      ))}
    </div>

    <p id="empty-state" class="hidden py-12 text-center text-muted">No projects with that tag… yet.</p>
  </section>
</BaseLayout>

<script>
  function initFilter() {
    const bar = document.getElementById('filter-bar');
    const grid = document.getElementById('project-grid');
    const empty = document.getElementById('empty-state');
    if (!bar || !grid) return;

    const buttons = Array.from(bar.querySelectorAll('[data-filter]')) as HTMLButtonElement[];
    const cards = Array.from(grid.children) as HTMLElement[];

    bar.onclick = (e) => {
      const btn = (e.target as HTMLElement).closest('[data-filter]') as HTMLButtonElement | null;
      if (!btn) return;
      const filter = btn.dataset.filter!;

      buttons.forEach((b) => {
        const active = b === btn;
        b.classList.toggle('bg-accent', active);
        b.classList.toggle('text-white', active);
        b.classList.toggle('glass', !active);
        b.classList.toggle('text-muted', !active);
      });

      let shown = 0;
      cards.forEach((c) => {
        const tags = (c.dataset.tags || '').split(',');
        const match = filter === 'All' || tags.includes(filter);
        c.style.display = match ? '' : 'none';
        if (match) shown++;
      });
      empty?.classList.toggle('hidden', shown > 0);
    };
  }
  document.addEventListener('astro:page-load', initFilter);
</script>
