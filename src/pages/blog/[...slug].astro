---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Giscus from '@/components/Giscus.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content } = await post.render();

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Rough reading time from the raw body.
const words = post.body.trim().split(/\s+/).length;
const readingTime = Math.max(1, Math.round(words / 200));
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="mx-auto max-w-3xl py-12">
    <a href="/blog" class="mb-8 inline-flex items-center gap-1 text-sm text-muted link-underline hover:text-ink">
      ← Back to blog
    </a>

    <header class="mb-8">
      <div class="mb-4 text-5xl">{post.data.emoji}</div>
      <h1 class="font-display text-4xl font-bold leading-tight text-balance sm:text-5xl">
        {post.data.title}
      </h1>
      <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-muted">
        <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
        <span class="opacity-40">·</span>
        <span>{readingTime} min read</span>
        {post.data.tags.map((t) => <span class="tag !py-0.5 !text-[10px]">#{t}</span>)}
      </div>
    </header>

    <div
      class="prose-custom max-w-none leading-relaxed
             [&_a]:text-accent [&_a:hover]:underline
             [&_blockquote]:border-l-2 [&_blockquote]:border-accent [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-muted
             [&_code]:rounded [&_code]:bg-accent/10 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:font-mono [&_code]:text-sm [&_code]:text-accent
             [&_h2]:mt-10 [&_h2]:font-display [&_h2]:text-2xl [&_h2]:font-bold
             [&_h3]:mt-8 [&_h3]:font-display [&_h3]:text-xl [&_h3]:font-bold
             [&_li]:my-1 [&_ul]:my-4 [&_ul]:list-disc [&_ul]:pl-6
             [&_p]:my-4 [&_p]:text-muted
             [&_pre]:my-6 [&_pre]:overflow-x-auto [&_pre]:rounded-xl [&_pre]:p-4
             [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:text-inherit"
    >
      <Content />
    </div>

    <hr class="my-12 border-white/10" />

    <h2 class="mb-6 font-display text-2xl font-bold">Comments</h2>
    <Giscus />
  </article>
</BaseLayout>
