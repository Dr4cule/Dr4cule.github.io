---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site, skills, timeline, socials, projects } from '@/config';

// Lightweight stats derived from config (no live API call at build time).
const totalStars = projects.reduce((n, p) => n + (p.stars ?? 0), 0);
const stats = [
  { label: 'Repositories', value: '12+' },
  { label: 'Total stars', value: `${totalStars}+` },
  { label: 'Coding since', value: '2024' },
  { label: 'Anime watched', value: '∞' },
];
---

<BaseLayout title="About" description={`About ${site.name}`}>
  <section class="py-12">
    <header class="mb-12 reveal">
      <span class="eyebrow">About me</span>
      <h1 class="mt-4 font-display text-4xl font-bold sm:text-5xl">
        The person behind <span class="gradient-text">{site.name}</span>
      </h1>
    </header>

    <div class="grid gap-8 lg:grid-cols-3">
      <!-- Bio + avatar -->
      <div class="glass rounded-2xl p-8 lg:col-span-2 reveal">
        <div class="mb-6 flex items-center gap-5">
          <img
            src={site.avatar}
            alt={site.name}
            width="80"
            height="80"
            class="avatar-ring h-20 w-20 shrink-0 rounded-full object-cover"
          />
          <div>
            <h2 class="font-display text-2xl font-bold">{site.name}</h2>
            <p class="text-sm text-muted">Developer · Automation enthusiast · Anime fan 👒</p>
          </div>
        </div>

        <div class="space-y-4 text-muted">
          <p class="text-lg leading-relaxed">{site.bio}</p>
          <p>
            Most of what I build comes from a simple itch: <em>"this is tedious — can I make
            a bot do it?"</em> That curiosity has led me through Discord bridges, computer-vision
            experiments, LLM tooling, and the occasional chaotic C program written for fun.
          </p>
          <p>
            I started on GitHub in {site.since} and have been shipping ever since. Always learning,
            always automating, and always one episode behind on my watchlist.
          </p>
        </div>

        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/contact" class="btn btn-primary">Work with me</a>
          {socials.github && (
            <a href={socials.github} target="_blank" rel="noopener" class="btn btn-ghost">GitHub ↗</a>
          )}
        </div>
      </div>

      <!-- Quick facts -->
      <div class="glass rounded-2xl p-8 reveal">
        <h2 class="mb-4 font-display text-xl font-bold">Quick facts</h2>
        <ul class="space-y-3 text-sm text-muted">
          <li class="flex items-center gap-3"><span class="text-accent">📍</span> {site.location}</li>
          <li class="flex items-center gap-3"><span class="text-accent">🤖</span> Automation &amp; bots</li>
          <li class="flex items-center gap-3"><span class="text-accent">🧠</span> Tinkering with LLMs &amp; CV</li>
          <li class="flex items-center gap-3"><span class="text-accent">🏴‍☠️</span> One Piece is peak fiction</li>
          <li class="flex items-center gap-3"><span class="text-accent">⌨️</span> JS · Python · C · TS</li>
        </ul>
      </div>
    </div>

    <!-- Stats row -->
    <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
      {stats.map((s) => (
        <div class="glass glass-hover rounded-2xl p-5 text-center reveal">
          <div class="font-display text-3xl font-bold gradient-text">{s.value}</div>
          <div class="mt-1 text-xs text-muted">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- Skills -->
    <div class="mt-8 glass rounded-2xl p-8 reveal">
      <h2 class="mb-5 font-display text-2xl font-bold">Things I work with</h2>
      <div class="flex flex-wrap gap-2">
        {skills.map((s) => <span class="tag text-sm">{s}</span>)}
      </div>
    </div>

    <!-- Timeline -->
    <div class="mt-8 reveal">
      <h2 class="mb-6 font-display text-2xl font-bold">The journey</h2>
      <ol class="relative ml-3 border-l border-white/15">
        {timeline.map((item) => (
          <li class="mb-8 ml-6">
            <span
              class="absolute -left-[9px] grid h-4 w-4 place-items-center rounded-full"
              style="background-color: rgb(var(--accent));"
            ></span>
            <div class="glass rounded-xl p-5">
              <span class="font-mono text-xs text-accent">{item.year}</span>
              <h3 class="mt-1 font-semibold">{item.title}</h3>
              <p class="mt-1 text-sm text-muted">{item.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>
</BaseLayout>
